{
   "format_version":"1.26.10",
   "minecraft:entity":{
      "description":{
         "identifier":"eoa:lich",
         "spawn_category":"creature",
         "is_spawnable":true,
         "is_summonable":true
      },
      "component_groups":{
         "eoa:lich_equipment":{
            "minecraft:equipment":{
               "table":"loot_tables/entities/lich_gear.json",
               "slot_drop_chance":[
                  {
                     "slot":"slot.weapon.mainhand",
                     "drop_chance":0.0
                  }
               ]
            }
         },
         "eoa:lich_breaks_doors":{
            "minecraft:annotation.break_door":{
               
            }
         },
         "eoa:lich_normal":{
            "minecraft:behavior.melee_box_attack":{
               "priority":3,
               "can_spread_on_fire":true,
               "speed_multiplier":1.2
            }
         },
         "eoa:lich_stunned":{
            "minecraft:is_stunned":{
               
            },
            "minecraft:timer":{
               "looping":false,
               "time":2.0,
               "time_down_event":{
                  "event":"eoa:lich_start_roar",
                  "target":"self"
               }
            }
         },
         "eoa:lich_roaring":{
            "minecraft:behavior.knockback_roar":{
               "priority":1,
               "duration":1.2,
               "attack_time":0.5,
               "knockback_damage":8,
               "knockback_horizontal_strength":4,
               "knockback_vertical_strength":1,
               "knockback_range":5,
               "knockback_filters":{
                  "test":"is_family",
                  "subject":"other",
                  "operator":"!=",
                  "value":"eoa:lich"
               },
               "damage_filters":{
                  "test":"is_family",
                  "subject":"other",
                  "value":"player"
               },
               "on_roar_end":{
                  "event":"eoa:lich_end_roar",
                  "target":"self"
               }
            }
         }
      },
      "components":{
         "minecraft:experience_reward":{
            "on_death":"query.last_hit_by_player ? 1200 : 0"
         },
         "minecraft:boss":{
            "should_darken_sky":false,
            "hud_range":64,
            "name":"entity.eoa:lich.name"
         },
         "minecraft:knockback_resistance":{
            "value":1.0
         },
         "minecraft:fire_immune":{
            
         },
         "minecraft:is_hidden_when_invisible":{
            
         },
         "minecraft:nameable":{
            
         },
         "minecraft:type_family":{
            "family":[
               "boss",
               "mob"
            ]
         },
         "minecraft:scale":{
            "value":1.5
         },
         "minecraft:equip_item":{
            "excluded_items":[
               {
                  "item":"minecraft:banner:15"
               }
            ]
         },
         "minecraft:collision_box":{
            "width":0.6,
            "height":1.9
         },
         "minecraft:movement.basic":{
            
         },
         "minecraft:navigation.walk":{
            "can_pass_doors":true,
            "can_walk":true,
            "can_break_doors":true,
            "avoid_damage_blocks": true,
            "avoid_water": true,
            "can_path_over_water": true,
            "can_sink":false      
         },
         "minecraft:jump.static":{
            
         },
         "minecraft:can_climb":{
            
         },
         "minecraft:health":{
            "value":750,
            "max":750
         },
         "minecraft:hurt_on_condition":{
            "damage_conditions":[
               {
                  "filters":{
                     "test":"in_lava",
                     "subject":"self",
                     "operator":"==",
                     "value":true
                  },
                  "cause":"lava",
                  "damage_per_tick":4
               }
            ]
         },
         "minecraft:breathable":{
            "total_supply":15,
            "suffocate_time":0,
            "breathes_air":true,
            "breathes_water":true
         },
         "minecraft:attack":{
            "damage":12
         },
         "minecraft:loot":{
            "table":"loot_tables/entities/lich.json"
         },
         "minecraft:despawn":{
            "despawn_from_distance":{
               "min_distance":128,
               "max_distance":192
            }
         },
         "minecraft:break_blocks":{
            "breakable_blocks":[
               "acacia_planks",
               "birch_planks",
               "dark_oak_planks",
               "jungle_planks",
               "oak_planks",
               "spruce_planks",
               "crimson_planks",
               "warped_planks",
               "acacia_fence",
               "birch_fence",
               "dark_oak_fence",
               "jungle_fence",
               "oak_fence",
               "spruce_fence",
               "crimson_fence",
               "warped_fence",
               "nether_brick_fence",
               "iron_bars",
               "acacia_leaves",
               "birch_leaves",
               "dark_oak_leaves",
               "jungle_leaves",
               "oak_leaves",
               "spruce_leaves",
               "azalea_leaves",
               "flowering_azalea_leaves",
               "oak_wood",
               "spruce_wood",
               "birch_wood",
               "jungle_wood",
               "acacia_wood",
               "dark_oak_wood",
               "cobblestone",
               "mossy_cobblestone",
               "stone_bricks",
               "mossy_stone_bricks",
               "cracked_stone_bricks",
               "chiseled_stone_bricks",
               "brick_block",
               "nether_bricks",
               "red_nether_bricks",
               "prismarine",
               "prismarine_bricks",
               "dark_prismarine",
               "end_bricks",
               "purpur_block",
               "purpur_pillar",
               "stone",
               "polished_andesite",
               "polished_diorite",
               "polished_granite"
            ]
         },
         "minecraft:behavior.equip_item":{
            "priority":3
         },
         "minecraft:behavior.random_stroll":{
            "priority":8,
            "speed_multiplier":1
         },
         "minecraft:behavior.look_at_player":{
            "priority":9,
            "look_distance":64,
            "probability":0.02
         },
         "minecraft:behavior.random_look_around":{
            "priority":10
         },
         "minecraft:behavior.hurt_by_target":{
            "priority":2,
            "entity_types":[
               {
                  "filters":{
                     "test":"is_family",
                     "subject":"other",
                     "operator":"!=",
                     "value":"breeze"
                  }
               }
            ]
         },
         "minecraft:behavior.nearest_attackable_target":{
            "priority":4,
            "must_see":false,
            "reselect_targets":true,
            "within_radius":64.0,
            "must_see_forget_duration":17.0,
            "entity_types":[
               {
                  "filters":{
                     "test":"is_family",
                     "subject":"other",
                     "value":"player"
                  },
                  "max_dist":64
               }
            ]
         },
         "minecraft:physics":{
            
         },
         "minecraft:pushable_by_entity": {},
         "minecraft:pushable_by_block": {},
         "minecraft:movement":{
            "value":0.35
         },
         "minecraft:conditional_bandwidth_optimization":{
            
         },
         "minecraft:ravager_blocked":{
            "knockback_strength":3.0,
            "reaction_choices":[
               {
                  "weight":1,
                  "value":{
                     "event":"eoa:lich_become_stunned",
                     "target":"self"
                  }
               }
            ]
         }
      },
      "events":{
         "minecraft:entity_spawned":{
            "sequence":[
               {
                  "add":{
                     "component_groups":[
                        "eoa:lich_equipment",
                        "eoa:lich_normal"
                     ]
                  }
               },
               {
                  "randomize":[
                     {
                        "weight":10,
                        "add":{
                           "component_groups":[
                              "eoa:lich_breaks_doors"
                           ]
                        }
                     },
                     {
                        "weight":90
                     }
                  ]
               }
            ]
         },
         "eoa:lich_become_stunned":{
            "remove":{
               "component_groups":[
                  "eoa:lich_normal"
               ]
            },
            "add":{
               "component_groups":[
                  "eoa:lich_stunned"
               ]
            }
         },
         "eoa:lich_start_roar":{
            "remove":{
               "component_groups":[
                  "eoa:lich_stunned"
               ]
            },
            "add":{
               "component_groups":[
                  "eoa:lich_roaring"
               ]
            }
         },
         "eoa:lich_end_roar":{
            "remove":{
               "component_groups":[
                  "eoa:lich_roaring"
               ]
            },
            "add":{
               "component_groups":[
                  "eoa:lich_normal"
               ]
            }
         }
      }
   }
}